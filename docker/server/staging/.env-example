# Postgres for the staging stack (this compose brings its own DB up).
POSTGRES_DB=studybuddy-staging
POSTGRES_USER=studybuddy-staging
POSTGRES_PASSWORD=<staging-db-pw>

# Weaviate API auth (the compose enables apikey auth).
WEAVIATE_API_USER=studybuddy
WEAVIATE_API_KEY=<staging-weaviate-api-key>

# Infisical — backend fetches all app secrets at runtime from these.
# All other secrets (SECRET_KEY, MINIO_*, SMTP_*, ...) live in Infisical.
INFISICAL_API_URL=https://secrets.mojiverse.dev
INFISICAL_PROJECT_ID=c718ab79-f826-4a1a-baec-31e6cde24c39
INFISICAL_CLIENT_ID=<staging-machine-identity-client-id>
INFISICAL_CLIENT_SECRET=<staging-machine-identity-client-secret>
