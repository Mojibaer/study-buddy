POSTGRES_DB=studybuddy-prod
POSTGRES_USER=studybuddy-prod
POSTGRES_PASSWORD=<prod-db-pw>

MINIO_ROOT_USER=studybuddy
MINIO_ROOT_PASSWORD=<minio-secret-key>

# Infisical — backend fetches all app secrets at runtime from these.
INFISICAL_API_URL=https://secrets.mojiverse.dev
INFISICAL_PROJECT_ID=c718ab79-f826-4a1a-baec-31e6cde24c39
INFISICAL_CLIENT_ID=<prod-machine-identity-client-id>
INFISICAL_CLIENT_SECRET=<prod-machine-identity-client-secret>